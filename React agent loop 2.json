      "typeVersion": 4.4,
      "position": [
        256,
        64
      ],
      "id": "fee5c6b0-0173-4f2a-bca9-ddcc6adf0f96",
      "name": "LLMreasoning"
    },
    {
      "parameters": {
        "jsCode": "// Loop over input items and add a new field called 'myNewField' to the JSON of each one\nconst text = $json.choices?.[0]?.message?.content || \"\";\n\nconst actionMatch = text.match(/Action:\\s*(.*)/);\nconst inputMatch = text.match(/Action Input:\\s*(.*)/);\nconst finalMatch = text.match(/Final Answer:\\s*(.*)/);\n\nreturn [{\n  action: actionMatch ? actionMatch[1].trim() : null,\n  input: inputMatch ? inputMatch[1].trim() : null,\n  final: finalMatch ? finalMatch[1].trim() : null,\n  raw: text\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        432,
        96
      ],
      "id": "273fff8d-daa3-4299-9409-ecc9b7d029c8",
      "name": "Parse action"
    },
    {
      "parameters": {
        "jsCode": "// Loop over input items and add a new field called 'myNewField' to the JSON of each one\nlet expression = $json.input || \"\";\n\n// remove symbols like = or ?\nexpression = expression.replace(\"=\", \"\").replace(\"?\", \"\").trim();\n\nconst result = eval(expression);\n\nreturn [{\n  observation: result\n}];"
      },
