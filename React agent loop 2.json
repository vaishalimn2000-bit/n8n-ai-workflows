        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{\n  \"model\": \"openai/gpt-oss-120b\",\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"You are a ReAct agent.\\n\\nQuestion: what is 45*30\\n\\nThought: think step by step\\nAction: calculator or none\\nAction Input: math expression\\nObservation:\\n\\nIf you know the answer:\\nFinal Answer: answer\\n\\nRules: Action must be either \\\"calculator\\\" or \\\"none\\\"\"\n    }\n  ]\n}",
        "options": {}
      },
